CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Optional. Marine weather lookups (marine_weather.py) work fine without this -
# they use Open-Meteo's free, keyless tier by default. Only set this if you've
# signed up for Open-Meteo's paid "customer" tier (higher rate limits) and want
# adventure creation to use it instead.
OPEN_METEO_API_KEY=

# Database. Unset -> sqlite:///./svel.db (no Docker needed).
# `docker compose up` runs a local Postgres container and sets this for you -
# local Docker value for now, swap for the real credential in Month 4, not before.
DATABASE_URL=postgresql://svel:svel@localhost:5432/svel

# S3-compatible object storage for uploaded photos. MinIO and Cloudflare R2
# both speak the same S3 API, so these names are generic on purpose - only the
# values change when this points at a real bucket. Leave all of these unset to
# fall back to saving uploads on local disk (backend/uploads/).
# local Docker value for now - swap for the real credential in Month 4, not before.
S3_ENDPOINT_URL=http://localhost:9000
# local Docker value for now - swap for the real credential in Month 4, not before.
S3_ACCESS_KEY_ID=minioadmin
# local Docker value for now - swap for the real credential in Month 4, not before.
S3_SECRET_ACCESS_KEY=minioadmin
# local Docker value for now - swap for the real credential in Month 4, not before.
S3_BUCKET_NAME=svel-photos
# local Docker value for now - swap for the real credential in Month 4, not before.
S3_PUBLIC_BASE_URL=http://localhost:9000/svel-photos

# CORS. Comma-separated list of allowed origins. Unset -> local Expo dev
# origins only (localhost:8081, localhost:19006). svel.app is added here only
# in Month 4, as an env value - no code change needed.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Rate limiting (slowapi), e.g. "120/minute". Unset -> 120/minute.
RATE_LIMIT_DEFAULT=120/minute

# Structured JSON logging level. Unset -> INFO.
LOG_LEVEL=INFO

# Photo upload moderation (moderation.py, routes/uploads.py). Sightengine's
# free tier (2,000 operations/month, no expiration) - sign up at
# https://sightengine.com. Required for automated moderation to run at all;
# see backend/MODERATION.md for what happens when these are unset/wrong
# (uploads still succeed, fail-open, but are flagged for a later recheck).
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# Optional. How confident (0-1) Sightengine must be that an image falls in
# its sexual_activity/sexual_display/erotica bands before it's rejected.
# Unset -> 0.5. See backend/MODERATION.md for the reasoning and known
# false-positive/false-negative tradeoffs before changing this.
MODERATION_NUDITY_THRESHOLD=0.5
